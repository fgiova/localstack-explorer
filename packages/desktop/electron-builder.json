{
  "appId": "com.localstack-explorer.app",
  "productName": "LocalStack Explorer",
  "files": [
    "main.cjs",
    "bundle.cjs",
    "public/**/*",
    "icon.png"
  ],
  "mac": {
    "category": "public.app-category.developer-tools",
    "icon": "icon.png",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ]
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Development"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "ia32"]
      }
    ],
    "icon": "icon.png"
  },
  "directories": {
    "output": "out"
  }
}
